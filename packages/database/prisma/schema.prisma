// LostInVirtual Citizen Registry Database Schema
// Prisma ORM - PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  ADMIN
  CITIZEN
  VISITOR
}

enum MerchandiseType {
  TSHIRT
  HOODIE
  JACKET
  CAP
}

enum TokenStatus {
  UNUSED
  ACTIVATED
  SUSPENDED
}

// ============================================================
// CORE TABLES
// ============================================================

/// Keycloak bridge - local user profiles
model User {
  id          String    @id @default(uuid()) @db.Uuid
  keycloakId  String    @unique @map("keycloak_id")
  username    String    @unique
  email       String    @unique
  displayName String?   @map("display_name")
  role        UserRole  @default(VISITOR)
  avatarUrl   String?   @map("avatar_url")
  preferences Json?     @default("{}")
  lastLoginAt DateTime? @map("last_login_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  citizen Citizen?
  tokens  Token[]

  @@map("users")
}

/// Merchandise activation codes
model Token {
  id              String          @id @default(uuid()) @db.Uuid
  code            String          @unique
  merchandiseType MerchandiseType @map("merchandise_type")
  batchNumber     String?         @map("batch_number")
  status          TokenStatus     @default(UNUSED)
  activatedBy     String?         @map("activated_by") @db.Uuid
  activatedAt     DateTime?       @map("activated_at")
  createdAt       DateTime        @default(now()) @map("created_at")

  // Relations
  user User? @relation(fields: [activatedBy], references: [id])

  @@map("tokens")
}

/// Activated citizen profile
model Citizen {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @unique @map("user_id") @db.Uuid
  citizenNumber String   @unique @map("citizen_number")
  regionId      String?  @map("region_id") @db.Uuid
  latitude      Float?
  longitude     Float?
  city          String?
  country       String?
  countryCode   String?  @map("country_code")
  activatedAt   DateTime @map("activated_at")
  bio           String?
  socialLinks   Json?    @map("social_links")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  region       Region?              @relation(fields: [regionId], references: [id])
  achievements CitizenAchievement[]

  @@map("citizens")
}

/// World map regions
model Region {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  countryCode  String   @unique @map("country_code")
  latitude     Float
  longitude    Float
  zoomLevel    Int      @default(5) @map("zoom_level")
  citizenCount Int      @default(0) @map("citizen_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  citizens Citizen[]

  @@map("regions")
}

/// Achievement badges
model Achievement {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String
  icon        String
  category    String
  points      Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  citizens CitizenAchievement[]

  @@map("achievements")
}

/// Join table for citizen-achievement relationship
model CitizenAchievement {
  citizenId     String   @map("citizen_id") @db.Uuid
  achievementId String   @map("achievement_id") @db.Uuid
  earnedAt      DateTime @default(now()) @map("earned_at")

  // Relations
  citizen     Citizen     @relation(fields: [citizenId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@id([citizenId, achievementId])
  @@map("citizen_achievements")
}
