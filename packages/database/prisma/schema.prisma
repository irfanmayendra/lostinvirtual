// LostInVirtual Citizen Registry Database Schema
// Prisma ORM - PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  SUPERADMIN
  ADMIN
  MODERATOR
  CITIZEN
  VISITOR
}

enum MerchandiseType {
  TSHIRT
  HOODIE
  JACKET
  CAP
}

enum TokenStatus {
  UNUSED
  ACTIVATED
  SUSPENDED
}

// ============================================================
// CORE TABLES
// ============================================================

/// Keycloak bridge - local user profiles
model User {
  id          String    @id @default(uuid()) @db.Uuid
  keycloakId  String    @unique @map("keycloak_id")
  username    String    @unique
  email       String    @unique
  displayName String?   @map("display_name")
  role        UserRole  @default(VISITOR)
  avatarUrl   String?   @map("avatar_url")
  preferences Json?     @default("{}")
  lastLoginAt DateTime? @map("last_login_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  citizen     Citizen?
  tokens      Token[]
  permissions UserPermission[]
  auditLogs   AuditLog[]

  @@map("users")
}

/// Merchandise activation codes
model Token {
  id              String          @id @default(uuid()) @db.Uuid
  code            String          @unique
  merchandiseType MerchandiseType @map("merchandise_type")
  batchNumber     String?         @map("batch_number")
  status          TokenStatus     @default(UNUSED)
  activatedBy     String?         @map("activated_by") @db.Uuid
  activatedAt     DateTime?       @map("activated_at")
  createdAt       DateTime        @default(now()) @map("created_at")

  // Relations
  user User? @relation(fields: [activatedBy], references: [id])

  @@map("tokens")
}

/// Activated citizen profile
model Citizen {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @unique @map("user_id") @db.Uuid
  citizenNumber String   @unique @map("citizen_number")
  regionId      String?  @map("region_id") @db.Uuid
  latitude      Float?
  longitude     Float?
  city          String?
  country       String?
  countryCode   String?  @map("country_code")
  activatedAt   DateTime @map("activated_at")
  bio           String?
  socialLinks   Json?    @map("social_links")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  region       Region?              @relation(fields: [regionId], references: [id])
  achievements CitizenAchievement[]

  @@map("citizens")
}

/// World map regions
model Region {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  countryCode  String   @unique @map("country_code")
  latitude     Float
  longitude    Float
  zoomLevel    Int      @default(5) @map("zoom_level")
  citizenCount Int      @default(0) @map("citizen_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  citizens Citizen[]

  @@map("regions")
}

/// Achievement badges
model Achievement {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String
  icon        String
  category    String
  points      Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  citizens CitizenAchievement[]

  @@map("achievements")
}

/// Join table for citizen-achievement relationship
model CitizenAchievement {
  citizenId     String   @map("citizen_id") @db.Uuid
  achievementId String   @map("achievement_id") @db.Uuid
  earnedAt      DateTime @default(now()) @map("earned_at")

  // Relations
  citizen     Citizen     @relation(fields: [citizenId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@id([citizenId, achievementId])
  @@map("citizen_achievements")
}

// ============================================================
// RBAC TABLES
// ============================================================

/// Role definitions with hierarchy levels
model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  level       Int      @unique // 0=VISITOR, 20=CITIZEN, 60=MODERATOR, 80=ADMIN, 100=SUPERADMIN
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  permissions RolePermission[]

  @@map("roles")
}

/// Granular permissions (module.action pattern)
model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique // e.g. "citizens.read", "tokens.create"
  module      String // e.g. "citizens", "tokens", "regions", "settings"
  action      String // e.g. "read", "create", "update", "delete"
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  roles RolePermission[]
  users UserPermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserPermission {
  userId       String     @map("user_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@map("user_permissions")
}

/// CMS - Dynamic page content management
model PageContent {
  id        String   @id @default(uuid()) @db.Uuid
  page      String // "landing", "login", "signup"
  section   String // "hero", "features", "howItWorks", "cta"
  key       String // "title", "subtitle", "ctaText", "description"
  value     String   @db.Text
  type      String   @default("text") // text, image, json, boolean
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([page, section, key])
  @@map("page_contents")
}

/// System audit trail
model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String // e.g. "user.promote", "token.revoke"
  entity    String // e.g. "user", "token", "region"
  entityId  String?  @map("entity_id")
  details   Json?
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}
